function normalizeLatex(str){
  return (str || "")
    .toLowerCase()
    .replace(/\frac/g,"frac")
    .replace(/\sqrt/g,"sqrt")
    .replace(/[{}\^_]/g,"")
    .replace(/s+/g,"")
    .trim();
}

document.getElementById("searchBox").addEventListener("input",(e)=>{

  const term = normalizeLatex(e.target.value);

  const filtered = questions.filter(q =>

    normalizeLatex(q.text).includes(term) ||

    q.options.some(o =>
      normalizeLatex(o).includes(term)
    ) ||

    (q.extraBox &&
      normalizeLatex(q.extraBox).includes(term)
    ) ||

    (q.explanation &&
      normalizeLatex(q.explanation).includes(term)
    ) ||

    (
      q.table &&
      normalizeLatex(
        q.table.replace(/<[^>]*>/g," ")
      ).includes(term)
    )

  );

  render(filtered, term);

});

  
