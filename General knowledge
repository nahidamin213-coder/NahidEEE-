function renderStatsPanel(){
  const statsContent = document.getElementById("statsContent");

  let correct=[], wrong=[], pending=[];
  let totalScore=0;

  questions.forEach(q=>{
    if(q.answered){
      if(q.gotCorrect){
        correct.push(q.id);
        totalScore += Number(q.mark || 1);
      } else {
        wrong.push(q.id);
        totalScore -= Number(q.negative || 0);
      }
    } else {
      pending.push(q.id);
    }
  });

  statsContent.innerHTML =
    "<p>🏆 স্কোর: " + totalScore + "</p>" +
    "<p>✔ সঠিক: " + correct.length + "</p>" +
    "<p>❌ ভুল: " + wrong.length + "</p>";
}
