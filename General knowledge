function highlight(text,term){

if(!term) return text;

const parts = text.split(
/(\(.*?\)|\[.*?\]|$.*?$|\begin{.*?}.*?\end{.*?})/g
);

return parts.map(part=>{

// LaTeX অংশ untouched থাকবে
if(
part.startsWith("\(") ||
part.startsWith("\[") ||
part.startsWith("$") ||
part.startsWith("\begin")
){
return part;
}

// normal text highlight হবে
const regex = new RegExp("(" + term + ")","gi");

return part.replace(regex,"<mark>$1</mark>");

}).join("");

}
  
