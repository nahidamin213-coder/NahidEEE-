if(!document.fullscreenElement){

document.documentElement.requestFullscreen();

}else{

document.exitFullscreen();

}

};
document.getElementById("scrollDown").onclick=()=>{

window.scrollTo({
top:document.body.scrollHeight,
behavior:"smooth"
});

};

const statsBtn=document.getElementById("statsBtn");

const statsPanel=document.getElementById("statsPanel");

const statsContent=document.getElementById("statsContent");
  document.getElementById("timeInput")
.addEventListener("focus",()=>{

setTimeout(()=>{

window.scrollTo({
top:0,
behavior:"instant"
});

},50);

});

statsBtn.onclick=()=>{

statsPanel.classList.toggle("show");

const correct=[];
const wrong=[];
const pending=[];

let totalScore=0;

questions.forEach(q=>{

if(q.answered){

if(q.gotCorrect){

correct.push(q.id);

totalScore += Number(q.mark || 1);

}else{

wrong.push(q.id);

totalScore -= Number(q.negative || 0);

}

}else{

pending.push(q.id);

}

});

  statsContent.innerHTML =
"<p>🏆 স্কোর: " + totalScore + "</p>" +

"<p>✔ সঠিক: " + correct.length + "</p>" +

"<p>❌ ভুল: " + wrong.length + "</p>" +

"<p><b>ভুল নং:</b><br>" + wrong.join(", ") + "</p>" +

"<p><b>বাকি:</b><br>" + pending.length + "</p>";

};

/*৬ষ্ঠ রিফ্রেশের ফাংশন যেটা বলে আগে টাইমার রিফ্রেশ থাকুন  */
  function showAlert(msg){

const box = document.getElementById("customAlert");

box.textContent = msg;

box.style.display = "block";

setTimeout(()=>{

box.style.display = "none";

},2000);

}
  /* ৬ষ্ঠ শেষ */
render();
updateCounters();
applyFontSize();
</script>

